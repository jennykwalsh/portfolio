---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Design portfolio for Jenny K Walsh" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <div class="header-backdrop"></div>

    <a href="/" class="nav-logo">
      <img src="/jennywalsh-signature.png" alt="Jenny K Walsh" />
    </a>

    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-dropdown" id="menu">
      <a href="/" class="nav-home">Home</a>
      <a href="/work">Work</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wave-divider">
        <svg viewBox="0 0 1440 45" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M 0,45 L 0,35 A 100,100 0 0,1 144,35 A 100,100 0 0,1 288,35 A 100,100 0 0,1 432,35 A 100,100 0 0,1 576,35 A 100,100 0 0,1 720,35 A 100,100 0 0,1 864,35 A 100,100 0 0,1 1008,35 A 100,100 0 0,1 1152,35 A 100,100 0 0,1 1296,35 A 100,100 0 0,1 1440,35 L 1440,45 Z" fill="#1a1a1a"/>
        </svg>
      </div>
      <div class="footer-content">
        <p class="footer-copy">&copy; 2026 Jenny K Walsh. All rights reserved.</p>
        <nav class="footer-nav">
          <a href="/work">Work</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </footer>

    <script>
      // Glitch effect on all h1s
      document.querySelectorAll('h1').forEach(h1 => {
        const words = h1.textContent.trim().split(/\s+/);
        h1.innerHTML = words.map(word => {
          const letters = [...word].map((char, i) =>
            `<span class="glitch-letter" data-char="${char}" style="--i:${i}">${char}</span>`
          ).join('');
          return `<span class="glitch-phrase">${letters}</span>`;
        }).join(' ');
      });

      const homeLink = document.querySelector('.nav-home') as HTMLElement | null;
      if (homeLink && window.location.pathname === '/') {
        homeLink.style.display = 'none';
      }

      // Load-in glitch: cascade left to right through each word, once
      // Skip on case study pages
      const isCaseStudy = window.location.pathname.startsWith('/work/');
      if (!isCaseStudy) {
        const isHome = window.location.pathname === '/';
        const delay = isHome ? 100 : 250;
        const phrases = document.querySelectorAll('.glitch-phrase');
        phrases.forEach((phrase, i) => {
          setTimeout(() => {
            phrase.classList.add('glitch-active');
            setTimeout(() => phrase.classList.remove('glitch-active'), 1800);
          }, i * delay);
        });
      }

      const hamburger = document.getElementById('hamburger');
      const menu = document.getElementById('menu');

      hamburger?.addEventListener('click', (e) => {
        e.stopPropagation();
        menu?.classList.toggle('open');
      });

      document.addEventListener('click', (e) => {
        if (!menu?.contains(e.target as Node)) menu?.classList.remove('open');
      });

      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => menu?.classList.remove('open'));
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
