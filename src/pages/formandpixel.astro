<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Form &amp; Pixel Arts Collective</title>
  <link rel="icon" type="image/x-icon" href="/about/formandpixel/formandpixelfavicon.ico" />
  <link rel="shortcut icon" href="/about/formandpixel/formandpixelfavicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* ── Desktop ── */
    body {
      background: #ffffff;
      font-family: 'Playfair Display', Georgia, serif;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 3rem 2rem;
      overflow-x: hidden;
    }

    .circle {
      flex-shrink: 0;
      border-radius: 50%;
      background: #1a1a1a;
      color: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 13% 9%;
      overflow: hidden;
      text-align: left;
    }

    .fp-logo {
      width: 75%;
      height: auto;
      display: block;
      flex-shrink: 0;
      object-fit: contain;
      margin-bottom: 1.75em;
    }

    p {
      font-size: clamp(1rem, 1.8vw, 1.1rem);
      line-height: 1.8;
      margin-bottom: 1em;
    }

    p:last-child {
      margin-bottom: 0;
    }

    strong em, em strong {
      font-weight: 700;
      font-style: italic;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* ── Mobile ── */
    @media (max-width: 600px) {
      body {
        background: #1a1a1a;
        display: block;
        padding: 0;
        min-height: 100vh;
      }

      .circle {
        all: unset;
        box-sizing: border-box;
        display: block;
        width: 100%;
        padding: 50px 20px;
        color: #ffffff;
        font-family: 'Playfair Display', Georgia, serif;
      }

      .circle .fp-logo {
        display: block;
        width: 70%;
        height: auto;
        margin: 0 auto 2em;
      }

      .circle p {
        display: block;
        font-size: 1rem;
        line-height: 1.8;
        margin-bottom: 1em;
        text-align: left;
        color: #ffffff;
      }

      .circle p:last-child {
        margin-bottom: 0;
      }
    }
  </style>
</head>
<body>
  <div class="circle">
    <img class="fp-logo" src="/about/formandpixel/logo-white.png" alt="Form &amp; Pixel Arts Collective" />
    <p>Form &amp; Pixel Arts Collective champions a wide array of creative services, including acrobatic instruction with <strong><em><a href="http://instagram.com/danielwalshacrobatics" target="_blank" rel="noopener">Duo Coalesce</a></em></strong>, and unique pottery creations from <strong><em><a href="http://thistlejar.com/" target="_blank" rel="noopener">Thistle Jar</a></em></strong>.</p>
    <p>At the heart of our collective, Form &amp; Pixel not only captures life's moments through stunning <strong><em><a href="https://formpixelphotography.pic-time.com/client" target="_blank" rel="noopener">photography</a></em></strong> but also innovative <strong><em><a href="https://jennykwalsh.com" target="_blank" rel="noopener">product design</a></em></strong>, merging aesthetics with functionality.</p>
    <p>Our commitment to creativity is not confined to these domains. We're continuously exploring and embracing new artistic endeavors, pushing the boundaries of what's possible.</p>
    <p style="text-align: center; margin-top: 1.25em;"><strong><em><a href="mailto:jennywalsh@hey.com">Contact us.</a></em></strong></p>
  </div>
  <script>
    const circle = document.querySelector('.circle');

    function fitCircle() {
      if (window.innerWidth <= 600) return;

      circle.style.width = '';
      circle.style.height = 'auto';
      circle.style.overflow = 'visible';

      const targetW = Math.min(Math.max(window.innerWidth * 0.72, 700), 900);
      circle.style.width = targetW + 'px';

      const contentH = circle.scrollHeight;
      const size = Math.max(targetW, contentH);
      circle.style.width = size + 'px';
      circle.style.height = size + 'px';
      circle.style.overflow = 'hidden';
    }

    fitCircle();
    window.addEventListener('resize', fitCircle);
  </script>
</body>
</html>
