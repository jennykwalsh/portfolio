---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Jenny K Walsh — [PAGE TITLE]">
  <div class="case-study">

    <div class="case-study-header">
      <p class="label">[Company] &nbsp;·&nbsp; Case study</p>
      <h1>[Project Title]</h1>
      <p class="role">[Job Title]</p>
    </div>

    <div class="hero-image">
      <img src="/work/[project-folder]/hero.webp" alt="[Project Title]" />
    </div>

    <div class="content">

      <section class="intro">
        <p>[Intro paragraph — 2-3 sentences setting the scene.]</p>
      </section>

      <section class="section">
        <h2>The problem</h2>
        <div class="section-body">
          <p>[Problem paragraph 1]</p>
          <p>[Problem paragraph 2]</p>
        </div>
      </section>

      <section class="section">
        <h2>My proposed solution</h2>
        <div class="section-body">
          <p>[Solution paragraph 1]</p>
          <p>[Solution paragraph 2]</p>
          <!-- Optional: image inside section -->
          <div class="image-break">
            <img src="/work/[project-folder]/[image].webp" alt="" />
          </div>
        </div>
      </section>

    </div>

    <!-- Optional: full-bleed image row (phone screens, etc.) -->
    <div class="phone-carousel">
      <img src="/work/[project-folder]/screen1.webp" alt="" />
      <img src="/work/[project-folder]/screen2.webp" alt="" />
      <img src="/work/[project-folder]/screen3.webp" alt="" />
      <img src="/work/[project-folder]/screen4.webp" alt="" />
      <img src="/work/[project-folder]/screen5.webp" alt="" />
      <img src="/work/[project-folder]/screen6.webp" alt="" />
    </div>

    <div class="content">

      <section class="section">
        <h2>My approach</h2>
        <div class="section-body">
          <p>[Approach paragraph 1]</p>
          <p>[Approach paragraph 2]</p>
        </div>
      </section>

    </div>

    <div class="content content-lower">

      <section class="section outcome">
        <h2>Outcome</h2>
        <div class="section-body">
          <div class="stats">
            <div class="stat">
              <span class="stat-number">[+X%]</span>
              <span class="stat-label">[Metric label]</span>
            </div>
            <div class="stat">
              <span class="stat-number">[+X%]</span>
              <span class="stat-label">[Metric label]</span>
            </div>
            <div class="stat">
              <span class="stat-number">[$XMM]</span>
              <span class="stat-label">[Metric label]</span>
            </div>
          </div>
          <p>[Outcome summary paragraph.]</p>
        </div>
      </section>

      <!-- Optional: closing full-width image -->
      <div class="image-break">
        <img src="/work/[project-folder]/[closing-image].webp" alt="" />
      </div>

      <div class="back-link">
        <a href="/work">← All work</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .case-study {
    padding-bottom: 8rem;
    overflow-x: hidden;
  }

  .case-study-header {
    padding: 180px 3rem 3rem;
    max-width: 1200px;
  }

  .label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--black);
    margin-bottom: 0.35rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    margin: 1rem 0;
  }

  .role {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    background: var(--black);
    padding: 0.3rem 0.75rem;
  }

  .hero-image {
    width: 100%;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .content {
    max-width: 1200px;
    padding: 0;
    margin: 0 auto;
  }

  .intro {
    padding: 4rem 3rem;
  }

  .intro p {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.75;
    font-weight: 300;
  }

  .section {
    padding: 4rem 3rem;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  h2 {
    font-size: 1.4rem;
    font-weight: 900;
    line-height: 1.2;
    padding-top: 0.25rem;
  }

  .section-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .image-break {
    margin: 1rem 0 0;
  }

  .image-break img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  .image-break.two-up {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .phone-carousel {
    display: flex;
    flex-direction: row;
    gap: 15px;
    padding: 1rem 20px 3rem;
  }

  .phone-carousel img {
    flex: 1 1 0;
    width: 0;
    height: auto;
    display: block;
  }

  .outcome {
    background: var(--black);
    color: var(--white);
    padding: 4rem 3rem;
    border-radius: 4px;
    border-top: none;
    grid-template-columns: 1fr;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 0.5rem 0 2rem;
  }

  .outcome h2 {
    color: #F6FF00;
  }

  .outcome .section-body {
    gap: 1.5rem;
  }

  .stats {
    display: flex;
    gap: 4rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #F6FF00;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .back-link {
    padding: 4rem 3rem 0;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .back-link a {
    font-size: 1rem;
    font-weight: 700;
    color: var(--black);
    text-decoration: none;
    background-color: #F6FF00;
    padding: 0 4px;
    display: inline-block;
    transition: box-shadow 0.1s steps(2), transform 0.1s steps(2);
  }

  .back-link a:hover {
    transform: translateY(-2px);
    box-shadow: 6px 3px 0 #00FFFF, -6px -3px 0 #FF00FF;
  }

  @media (max-width: 768px) {
    .case-study-header {
      padding: 160px 1.5rem 2rem;
    }

    .content {
      padding: 0 1.5rem;
    }

    .intro {
      padding: 2rem 0;
    }

    .section {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
    }

    .back-link {
      padding: 2rem 0 0;
    }

    .image-break.two-up {
      grid-template-columns: 1fr 1fr;
    }

    .content-lower {
      padding-left: 0;
      padding-right: 0;
    }

    .outcome {
      padding: 2rem;
    }

    .stats {
      flex-direction: column;
      gap: 2rem;
    }

    .phone-carousel {
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 12px;
      padding: 1rem 0 0.5rem;
      margin: 0;
    }

    .phone-carousel img {
      width: 82vw;
      flex: none;
      scroll-snap-align: center;
      border-radius: 8px;
    }

    .phone-carousel img:first-child {
      margin-left: calc(50vw - 41vw);
    }

    .phone-carousel img:last-child {
      margin-right: calc(50vw - 41vw);
    }
  }
</style>
