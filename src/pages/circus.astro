<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jenny K Walsh — Performance</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300..800&family=Playfair+Display:ital,wght@0,400;1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #1a1a1a;
      color: #fff;
      font-family: 'Funnel Display', sans-serif;
      overflow-x: hidden;
    }

    /* ── NAV LOGO ── */
    .nav-logo {
      position: fixed;
      top: 1.5rem;
      left: 2rem;
      z-index: 99;
      text-decoration: none;
      opacity: 0.9;
      transition: opacity 0.2s;
      mix-blend-mode: multiply;
    }

    .nav-logo img {
      height: 120px;
      width: auto;
      display: block;
    }

    .nav-logo:hover { opacity: 1; }

    @media (max-width: 768px) {
      .nav-logo { left: 12px; }
    }

    /* ── HAMBURGER ── */
    .hamburger {
      position: fixed;
      top: calc(1.5rem + 60px);
      transform: translateY(-50%);
      right: 2rem;
      z-index: 99;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .hamburger span {
      display: block;
      height: 5px;
      background: #fff;
      transition: all 0.3s ease;
    }

    .hamburger span:nth-child(1) { width: 32px; }
    .hamburger span:nth-child(2) { width: 32px; }
    .hamburger span:nth-child(3) { width: 22px; }

    /* ── NAV DROPDOWN ── */
    .nav-dropdown {
      position: fixed;
      top: calc(1.5rem + 120px + 0.5rem);
      right: 2rem;
      z-index: 200;
      background: #1a1a1a;
      display: flex;
      flex-direction: column;
      padding: 1.25rem 2rem 1.25rem 1.5rem;
      gap: 0.5rem;
      transform-origin: top right;
      transform: scale(0.85);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease, transform 0.15s ease;
    }

    .nav-dropdown.open {
      opacity: 1;
      pointer-events: auto;
      transform: scale(1);
    }

    .nav-dropdown a {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
      text-decoration: none;
      white-space: nowrap;
      transition: color 0.1s;
    }

    .nav-dropdown a:hover { color: #F6FF00; }

    /* ── HERO ── */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100svh;
      display: flex;
      align-items: flex-end;
    }

    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 25%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.2) 0%,
        rgba(0,0,0,0) 35%,
        rgba(26,26,26,0.85) 100%
      );
    }

    .hero-text {
      position: relative;
      z-index: 2;
      padding: 2rem 1.5rem 3rem;
      width: 100%;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      opacity: 0.5;
      margin-bottom: 0.5rem;
    }

    .hero-text h1 {
      font-size: clamp(4rem, 16vw, 9rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.03em;
      color: #fff;
    }

    .hero-text h1 .accent {
      color: #F6FF00;
      display: block;
    }

    /* ── BIO ── */
    .bio {
      padding: 4rem 1.5rem 3rem;
      max-width: 760px;
    }

    .bio p {
      font-size: clamp(1.05rem, 2.5vw, 1.25rem);
      line-height: 1.75;
      font-weight: 300;
      color: rgba(255,255,255,0.85);
    }

    .bio p strong {
      color: #F6FF00;
      font-weight: 700;
    }

    .dark-link {
      color: #F6FF00;
      text-decoration: none;
      background-color: rgba(255,255,255,0.1);
      padding: 0 4px;
      display: inline-block;
      position: relative;
      transition: box-shadow 0.1s steps(2), transform 0.1s steps(2);
    }

    .dark-link:hover {
      transform: translateY(-2px);
      box-shadow: 6px 3px 0 #00FFFF, -6px -3px 0 #FF00FF;
    }

    @keyframes dark-link-glitch {
      0%   { transform: scale(0.95);                                background: #F6FF00; color: #1a1a1a; box-shadow:  6px  3px 0 #00FFFF, -6px -3px 0 #FF00FF; }
      20%  { transform: scale(1.05) skewX(-5deg) translateY(-3px); background: #1a1a1a; color: #F6FF00; box-shadow:  6px  3px 0 #FF00FF, -6px -3px 0 #00FFFF; }
      40%  { transform: scale(0.98) skewX(3deg)  translateY(-1px); background: #00FFFF; color: #1a1a1a; box-shadow: -6px -3px 0 #FF00FF,  6px  3px 0 #F6FF00; }
      65%  { transform: scale(1.02)              translateY(-2px); background: #1a1a1a; color: #F6FF00; box-shadow:  6px  3px 0 #00FFFF, -6px -3px 0 #FF00FF; }
      100% { transform: scale(1)                 translateY(0);    background: rgba(255,255,255,0.1); color: #F6FF00; box-shadow: none; }
    }

    .dark-link-glitch-click {
      animation: dark-link-glitch 0.38s steps(1) forwards;
    }

    /* ── GALLERY ── */
    .gallery {
      padding-bottom: 5rem;
    }

    .gallery-section {
      padding: 3rem 1.5rem 1rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .section-title {
      font-size: clamp(1.75rem, 5vw, 3rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 1.5rem;
    }

    .section-title span {
      color: #F6FF00;
    }

    /* ── VIDEO GRID ── */
    .video-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    /* ── VIDEO CARD ── */
    .video-card {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: #111;
      cursor: pointer;
    }

    .video-card-thumb {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease, opacity 0.3s ease;
      opacity: 0.75;
    }

    .video-card:hover .video-card-thumb {
      transform: scale(1.04);
      opacity: 0.9;
    }

    .video-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.8) 0%,
        rgba(0,0,0,0.1) 50%,
        rgba(0,0,0,0) 100%
      );
    }

    .video-card-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -60%);
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(246,255,0,0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      color: #1a1a1a;
      transition: transform 0.2s ease, background 0.2s ease;
      padding-left: 3px;
    }

    .video-card:hover .video-card-play {
      transform: translate(-50%, -60%) scale(1.12);
      background: #F6FF00;
    }

    .video-card-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.9rem 1rem;
      z-index: 2;
    }

    .video-card-title {
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 0.2rem;
    }

    .video-card-tag {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      opacity: 0.45;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0,0,0,0.95);
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .lightbox.open {
      display: flex;
    }

    .lightbox-inner {
      position: relative;
      width: 90vw;
      max-width: 1400px;
      aspect-ratio: 16 / 9;
    }

    .lightbox-inner iframe {
      width: 100%;
      height: 100%;
      border: none;
    }

    .lightbox-close {
      position: fixed;
      top: 1rem;
      right: 1.25rem;
      font-size: 1.5rem;
      line-height: 1;
      color: #fff;
      opacity: 0.5;
      cursor: pointer;
      background: none;
      border: none;
      font-family: inherit;
      z-index: 1000;
      transition: opacity 0.2s;
    }

    .lightbox-close:hover { opacity: 1; }

    /* ── FOOTER ── */
    .page-footer {
      padding: 2rem 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .page-footer p {
      font-size: 0.8rem;
      font-weight: 300;
      opacity: 0.3;
      font-style: italic;
    }

    .home-link {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #fff;
      text-decoration: none;
      opacity: 0.4;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 1px;
      transition: opacity 0.2s;
    }

    .home-link:hover { opacity: 1; }

    /* ── RESPONSIVE ── */
    @media (min-width: 600px) {
      nav { padding: 1.5rem 3rem; }
      .hero-text { padding: 3rem 3rem 4rem; }
      .bio { padding: 5rem 3rem 4rem; }
      .gallery-section { padding: 3.5rem 3rem 1rem; }
      .video-grid { grid-template-columns: repeat(2, 1fr); }
      .page-footer { padding: 2rem 3rem 3rem; }
    }

    @media (min-width: 900px) {
      .video-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</head>
