---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jenny K Walsh — Performance</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300..800&family=Playfair+Display:ital,wght@0,400;1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #1a1a1a;
      color: #fff;
      font-family: 'Funnel Display', sans-serif;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: linear-gradient(to bottom, rgba(26,26,26,0.9) 0%, rgba(26,26,26,0) 100%);
    }

    nav .logo {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
      opacity: 0.7;
    }

    nav .logo:hover { opacity: 1; }

    nav .nav-links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
    }

    nav .nav-links a {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #fff;
      text-decoration: none;
      opacity: 0.5;
      transition: opacity 0.2s;
    }

    nav .nav-links a:hover { opacity: 1; }

    /* ── HERO ── */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100svh;
      display: flex;
      align-items: flex-end;
    }

    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.2) 0%,
        rgba(0,0,0,0) 35%,
        rgba(26,26,26,0.85) 100%
      );
    }

    .hero-text {
      position: relative;
      z-index: 2;
      padding: 2rem 1.5rem 3rem;
      width: 100%;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      opacity: 0.5;
      margin-bottom: 0.5rem;
    }

    .hero-text h1 {
      font-size: clamp(4rem, 16vw, 9rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.03em;
      color: #fff;
    }

    .hero-text h1 .accent {
      color: #F6FF00;
      display: block;
    }

    /* ── BIO SECTION ── */
    .bio {
      padding: 4rem 1.5rem 3rem;
      max-width: 760px;
    }

    .bio p {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(1.05rem, 2.5vw, 1.25rem);
      line-height: 1.75;
      font-weight: 400;
      color: rgba(255,255,255,0.85);
    }

    .bio p strong {
      font-style: italic;
      color: #F6FF00;
      font-weight: 400;
    }

    /* ── ACTS SECTION ── */
    .acts-intro {
      padding: 0 1.5rem 2rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 3rem;
    }

    .acts-intro .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      opacity: 0.35;
      margin-bottom: 0.75rem;
    }

    .acts-intro h2 {
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .acts-intro h2 span {
      color: #F6FF00;
    }

    /* ── ACT CARDS ── */
    .acts-grid {
      padding: 0 1.5rem 4rem;
      display: grid;
      gap: 1px;
      background: rgba(255,255,255,0.08);
    }

    .act-card {
      position: relative;
      background: #1a1a1a;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      min-height: 300px;
    }

    .act-card-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.4;
      transition: opacity 0.4s ease, transform 0.5s ease;
    }

    .act-card:hover .act-card-img {
      opacity: 0.6;
      transform: scale(1.03);
    }

    .act-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 60%);
    }

    .act-card-content {
      position: relative;
      z-index: 2;
      padding: 1.5rem;
    }

    .act-number {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.35;
      margin-bottom: 0.4rem;
    }

    .act-name {
      font-size: clamp(1.75rem, 6vw, 2.5rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .act-desc {
      font-size: 0.8rem;
      font-weight: 300;
      opacity: 0.6;
      line-height: 1.5;
      margin-bottom: 1.25rem;
      max-width: 280px;
    }

    .act-watch {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #1a1a1a;
      background: #F6FF00;
      text-decoration: none;
      padding: 0.5rem 1rem;
      transition: background 0.2s, color 0.2s;
    }

    .act-watch:hover {
      background: #fff;
    }

    .act-watch.coming-soon {
      background: transparent;
      color: rgba(255,255,255,0.25);
      border: 1px solid rgba(255,255,255,0.12);
      cursor: default;
      pointer-events: none;
      font-style: italic;
      letter-spacing: 0.06em;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0,0,0,0.93);
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .lightbox.open {
      display: flex;
    }

    .lightbox-inner {
      position: relative;
      width: 100%;
      max-width: 960px;
      aspect-ratio: 16 / 9;
    }

    .lightbox-inner iframe {
      width: 100%;
      height: 100%;
      border: none;
    }

    .lightbox-close {
      position: fixed;
      top: 1rem;
      right: 1.25rem;
      font-size: 1.5rem;
      line-height: 1;
      color: #fff;
      opacity: 0.5;
      cursor: pointer;
      background: none;
      border: none;
      font-family: inherit;
      z-index: 1000;
      transition: opacity 0.2s;
    }

    .lightbox-close:hover { opacity: 1; }

    /* ── FOOTER ── */
    .page-footer {
      padding: 2rem 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .page-footer p {
      font-size: 0.8rem;
      font-weight: 300;
      opacity: 0.3;
      font-style: italic;
      font-family: 'Playfair Display', Georgia, serif;
    }

    .home-link {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #fff;
      text-decoration: none;
      opacity: 0.4;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 1px;
      transition: opacity 0.2s;
    }

    .home-link:hover { opacity: 1; }

    /* ── RESPONSIVE ── */
    @media (min-width: 600px) {
      nav { padding: 1.5rem 3rem; }
      .hero-text { padding: 3rem 3rem 4rem; }
      .bio { padding: 5rem 3rem 4rem; }
      .acts-intro { padding: 3.5rem 3rem 2rem; }
      .acts-grid { padding: 0 3rem 5rem; grid-template-columns: repeat(2, 1fr); }
      .page-footer { padding: 2rem 3rem 3rem; }
    }

    @media (min-width: 900px) {
      .acts-grid { grid-template-columns: repeat(2, 1fr); }
      .act-card { min-height: 380px; }
      .act-card.featured { grid-column: 1 / -1; min-height: 460px; }
    }
  </style>
</head>
<body>

  <nav>
    <a class="logo" href="/">Jenny K Walsh</a>
    <ul class="nav-links">
      <li><a href="/work">Work</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img class="hero-img" src="/circus/hero.png" alt="Jenny Walsh performing aerial silks" />
    <div class="hero-overlay"></div>
    <div class="hero-text">
      <p class="hero-eyebrow">Circus &amp; Athletics</p>
      <h1>Per<span class="accent">form</span><span class="accent">ance</span></h1>
    </div>
  </section>

  <!-- BIO -->
  <div class="bio">
    <p>
      Performing arts and athletics have always been a part of my life. I spent the first 16 years
      as a competitive gymnast. As an adult, I transitioned to circus performance — beginning with
      aerial silks in 2012, then quickly expanding my repertoire as I took professional contracts
      with local productions. <strong>Duo Trapeze, Duo Silks, and Acrobatics</strong> took center
      stage, and now I perform with my life partner as <strong>Duo Coalesce</strong>.
    </p>
  </div>

  <!-- ACT CARDS -->
  <div class="acts-intro">
    <p class="section-label">On stage</p>
    <h2>The <span>acts</span></h2>
  </div>

  <div class="acts-grid">

    <div class="act-card featured">
      <img class="act-card-img" src="/circus/duo-coalesce.jpg" alt="Duo Coalesce" />
      <div class="act-card-overlay"></div>
      <div class="act-card-content">
        <p class="act-number">01</p>
        <h3 class="act-name">Duo Coalesce</h3>
        <p class="act-desc">Partner acrobatics and aerial performance with my collaborator and life partner.</p>
        <button class="act-watch coming-soon">More coming soon</button>
      </div>
    </div>

    <div class="act-card">
      <img class="act-card-img" src="/circus/aerial-silks.jpg" alt="Aerial Silks" />
      <div class="act-card-overlay"></div>
      <div class="act-card-content">
        <p class="act-number">02</p>
        <h3 class="act-name">Aerial Silks</h3>
        <p class="act-desc">Where it started — solo silks work since 2012.</p>
        <button class="act-watch coming-soon">More coming soon</button>
      </div>
    </div>

    <div class="act-card" data-video="6ad1uhG4K0M">
      <img class="act-card-img" src="/circus/duo-trapeze.jpg" alt="Duo Trapeze" />
      <div class="act-card-overlay"></div>
      <div class="act-card-content">
        <p class="act-number">03</p>
        <h3 class="act-name">Duo Trapeze</h3>
        <p class="act-desc" style="font-style:italic; font-family:'Playfair Display',serif;">"Ghost of Sky" — filmed in our backyard during the pandemic lockdown of 2020.</p>
        <button class="act-watch" data-video="6ad1uhG4K0M">▶ Watch</button>
      </div>
    </div>

    <div class="act-card">
      <img class="act-card-img" src="/circus/acrobatics.jpg" alt="Acrobatics" />
      <div class="act-card-overlay"></div>
      <div class="act-card-content">
        <p class="act-number">04</p>
        <h3 class="act-name">Acrobatics</h3>
        <p class="act-desc">Grounded partner work rooted in a lifetime of gymnastics.</p>
        <button class="act-watch coming-soon">More coming soon</button>
      </div>
    </div>

  </div>

  <footer class="page-footer">
    <p>Training and performing since 2012.</p>
    <a class="home-link" href="/">← home</a>
  </footer>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Video player">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close video">✕</button>
    <div class="lightbox-inner">
      <iframe
        id="lightbox-iframe"
        src=""
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="Performance video"
      ></iframe>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const iframe   = document.getElementById('lightbox-iframe');
    const closeBtn = document.getElementById('lightbox-close');

    function openVideo(videoId) {
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeVideo() {
      lightbox.classList.remove('open');
      iframe.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.act-watch[data-video]').forEach(btn => {
      btn.addEventListener('click', () => openVideo(btn.dataset.video));
    });

    closeBtn.addEventListener('click', closeVideo);

    lightbox.addEventListener('click', e => {
      if (e.target === lightbox) closeVideo();
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeVideo();
    });
  </script>

</body>
</html>
