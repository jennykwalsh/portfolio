  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Video player">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close video">✕</button>
    <div class="lightbox-inner">
      <iframe
        id="lightbox-iframe"
        src=""
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="Performance video"
      ></iframe>
    </div>
  </div>

  <script>
    document.querySelectorAll('.dark-link').forEach(link => {
      link.addEventListener('click', () => {
        link.classList.add('dark-link-glitch-click');
        link.addEventListener('animationend', () => link.classList.remove('dark-link-glitch-click'), { once: true });
      });
    });

    const hamburger = document.getElementById('hamburger');
    const menu = document.getElementById('menu');

    hamburger?.addEventListener('click', (e) => {
      e.stopPropagation();
      menu?.classList.toggle('open');
    });

    document.addEventListener('click', (e) => {
      if (!menu?.contains(e.target as Node)) menu?.classList.remove('open');
    });

    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => menu?.classList.remove('open'));
    });
  </script>

  <script>
    const lightbox = document.getElementById('lightbox');
    const iframe   = document.getElementById('lightbox-iframe');
    const closeBtn = document.getElementById('lightbox-close');

    function openVideo(videoId) {
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeVideo() {
      lightbox.classList.remove('open');
      iframe.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.video-card[data-video]').forEach(card => {
      card.addEventListener('click', () => openVideo(card.dataset.video));
    });

    closeBtn.addEventListener('click', closeVideo);

    lightbox.addEventListener('click', e => {
      if (e.target === lightbox) closeVideo();
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeVideo();
    });
  </script>

</body>
</html>
